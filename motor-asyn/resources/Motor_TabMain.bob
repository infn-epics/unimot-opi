    <style>3</style>
    <transparent>true</transparent>
    <widget type="progressbar" version="2.0.0">
      <name>Progress Bar</name>
      <pv_name>$(P)$(M).RBV</pv_name>
      <x>10</x>
      <width>382</width>
      <height>30</height>
      <rules>
        <rule name="max" prop_id="maximum" out_exp="true">
          <exp bool_exp="pvInt0">
            <expression>maximum value</expression>
          </exp>
          <pv_name>$(P)$(M).HLM</pv_name>
        </rule>
        <rule name="min" prop_id="minimum" out_exp="true">
          <exp bool_exp="pvInt0">
            <expression>minimum value</expression>
          </exp>
          <pv_name>$(P)$(M).LLM</pv_name>
        </rule>
      </rules>
    </widget>
  </widget>
