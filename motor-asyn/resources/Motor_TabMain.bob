      <y>4</y>
      <width>90</width>
      <height>22</height>
      <font>
        <font name="FLAME Label" family="Noto Sans" style="REGULAR" size="14.0">
        </font>
      </font>
      <foreground_color>
        <color name="FLAME Text Main" red="0" green="0" blue="0">
        </color>
      </foreground_color>
      <background_color>
        <color name="FLAME BackgroundButton" red="200" green="200" blue="200">
        </color>
      </background_color>
      <tooltip>$(actions)</tooltip>
    </widget>
